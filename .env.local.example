# Supabase — find these in your project's API settings
# Project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — server-only, NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Webhook endpoint provided by Secco Squared
WEBHOOK_URL=https://webhook-receiver-flax.vercel.app/api/lead-webhook
